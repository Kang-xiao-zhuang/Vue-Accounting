# Backend base URL used by the packaged (Capacitor) app — there is no dev proxy there.
#
# Android emulator (Android Studio) reaches your PC's localhost via the special
# host 10.0.2.2, so for the emulator use:
VITE_API_BASE=http://10.0.2.2:8030/api
#
# For a REAL phone on the same Wi-Fi, comment the line above and use your PC's
# LAN IP instead (find it with `ipconfig` -> IPv4 Address, e.g. 192.168.1.23):
# VITE_API_BASE=http://192.168.1.23:8030/api
